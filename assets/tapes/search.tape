Output assets/search.gif
Set Width 1000
Set Height 620
Set FontSize 18
Set Padding 12
Env PW_VAULT "/tmp/demo-vault/vault"
Env PATH "/home/dt/dev/pw-manager/venv/bin:/home/dt/.local/bin:/usr/local/bin:/usr/bin:/bin"

Hide
Type "pw"
Enter
Sleep 1.5s
Type "knight-demo"
Enter
Sleep 2.5s
Show

Sleep 1s
Type "/"
Sleep 800ms
Type@180ms "bank darsh"
Sleep 2.5s
Escape
Sleep 800ms
Type "/"
Type@180ms "beats"
Sleep 2.5s
Escape
Sleep 1.5s
