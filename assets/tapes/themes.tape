Output assets/themes.gif
Set Width 1000
Set Height 620
Set FontSize 18
Set Padding 12
Env PW_VAULT "/tmp/demo-vault/vault"
Env PATH "/home/dt/dev/pw-manager/venv/bin:/home/dt/.local/bin:/usr/local/bin:/usr/bin:/bin"

Hide
Type "paladin"
Enter
Sleep 1.5s
Type "knight-demo"
Enter
Sleep 2.5s
Show

Sleep 1s
Type "t"
Sleep 1.5s
Down
Sleep 1.2s
Down
Sleep 1.2s
Down
Sleep 1.2s
Up
Sleep 1.2s
Escape
Sleep 1.5s
