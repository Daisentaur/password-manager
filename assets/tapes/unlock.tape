Output assets/unlock.gif
Set Width 1000
Set Height 620
Set FontSize 18
Set Padding 12
Env PW_VAULT "/tmp/demo-vault/vault"
Env PATH "/home/dt/dev/pw-manager/venv/bin:/home/dt/.local/bin:/usr/local/bin:/usr/bin:/bin"

Type "paladin"
Sleep 500ms
Enter
Sleep 1.5s
Type@120ms "knight-demo"
Sleep 800ms
Enter
Sleep 2.5s
Sleep 2s
