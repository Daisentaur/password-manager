Output assets/palette.gif
Set Width 1000
Set Height 620
Set FontSize 18
Set Padding 12
Env PW_VAULT "/tmp/demo-vault/vault"
Env PATH "/home/dt/dev/pw-manager/venv/bin:/home/dt/.local/bin:/usr/local/bin:/usr/bin:/bin"

Hide
Type "pw"
Enter
Sleep 1.5s
Type "knight-demo"
Enter
Sleep 2.5s
Show

Sleep 1s
Ctrl+p
Sleep 1.5s
Type@150ms "master"
Sleep 2s
Escape
Sleep 500ms
Ctrl+p
Sleep 1s
Type@150ms "csv"
Sleep 2.5s
Escape
Sleep 1s
